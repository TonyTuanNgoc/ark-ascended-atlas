rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function atlasMeta() {
      return get(/databases/$(database)/documents/atlasMeta/default);
    }

    function ownerLockEnabled() {
      return exists(/databases/$(database)/documents/atlasMeta/default)
        && atlasMeta().data.cloud is map
        && atlasMeta().data.cloud.syncLock is map
        && atlasMeta().data.cloud.syncLock.mode == "owner";
    }

    function isOwner() {
      return isSignedIn()
        && ownerLockEnabled()
        && atlasMeta().data.cloud.syncLock.ownerUid == request.auth.uid;
    }

    function writesAllowed() {
      return isSignedIn() && (!ownerLockEnabled() || isOwner());
    }

    match /atlasMeta/default {
      allow read: if true;
      allow write: if writesAllowed();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if writesAllowed();
    }
  }
}
