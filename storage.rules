rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function atlasMeta() {
      return firestore.get(/databases/(default)/documents/atlasMeta/default);
    }

    function ownerLockEnabled() {
      return firestore.exists(/databases/(default)/documents/atlasMeta/default)
        && atlasMeta().data.cloud is map
        && atlasMeta().data.cloud.syncLock is map
        && atlasMeta().data.cloud.syncLock.mode == "owner";
    }

    function isOwner() {
      return isSignedIn()
        && ownerLockEnabled()
        && atlasMeta().data.cloud.syncLock.ownerUid == request.auth.uid;
    }

    function writesAllowed() {
      return isSignedIn() && (!ownerLockEnabled() || isOwner());
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if writesAllowed();
    }
  }
}
